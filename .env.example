# LeetCode Session Cookie
# Get this from your browser's developer tools -> Application -> Cookies -> leetcode.com
LEETCODE_SESSION=your_leetcode_session_cookie_here

# CSRF Token
# Get this from your browser's developer tools -> Application -> Cookies -> leetcode.com
CSRFTOKEN=your_csrf_token_here

# GitHub Repository URL (optional — needed only for auto-push)
GITHUB_REPO=https://github.com/USERNAME/LeetCode.git

# GitHub Branch (default: main)
GITHUB_BRANCH=main

# Output folder for downloaded solutions
OUTPUT_FOLDER=LeetCode
